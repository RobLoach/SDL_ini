# Doxyfile for SDL_ini

PROJECT_NAME           = "SDL_ini"
PROJECT_BRIEF          = "Single-header INI file library for SDL3"
PROJECT_NUMBER         = 1.0.0
OUTPUT_DIRECTORY       = docs
INPUT                  = SDL_ini.h README.md
USE_MDFILE_AS_MAINPAGE = README.md
RECURSIVE              = NO

# Build
EXTRACT_ALL            = YES
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_SCOPE_NAMES       = YES
SORT_MEMBER_DOCS       = NO
INTERNAL_DOCS          = NO
JAVADOC_AUTOBRIEF      = YES

# Warnings
QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES

# Output
DOXYFILE_ENCODING      = UTF-8
GENERATE_HTML          = YES
HTML_OUTPUT            = html
#HTML_COLORSTYLE        = DARK
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
GENERATE_LATEX         = NO
GENERATE_MAN           = NO

# Source
SOURCE_BROWSER         = NO
VERBATIM_HEADERS       = NO
STRIP_CODE_COMMENTS    = YES

# Preprocessor
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = SDLCALL= \
                         SDL_PRINTF_FORMAT_STRING= \
                         __DOXYGEN

OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
